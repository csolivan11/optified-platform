# ═══════════════════════════════════════════════════════════
# Optified — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values.
# Never commit .env.local.

# ─── Supabase ────────────────────────────────────────────────
# Local: printed by `supabase start`
# Staging/Prod: from the Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ─────────────────────────────────────────────────────
# Base URL of the deployed app. Used in outbound email links.
# Local: http://localhost:3000
# Staging: https://staging.optified.com (or Vercel preview URL)
# Prod: https://app.optified.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Resend (transactional email) ────────────────────────────
# Get API key from https://resend.com/api-keys
# DNS for the sending domain (optified.com) must be verified in Resend
# BEFORE these addresses can send. See README for setup.
RESEND_API_KEY=

# From-addresses. Must be on a domain verified in Resend.
# noreply@   — account notifications, welcome emails
# accounts@  — invitations, password resets, account changes
# coach@     — future: coach-initiated messages (Phase 5+)
EMAIL_FROM_NOREPLY=noreply@optified.com
EMAIL_FROM_ACCOUNTS=accounts@optified.com
EMAIL_FROM_COACH=coach@optified.com

# ─── Oura (Phase 4, beta week 2) ─────────────────────────────
# Register app at https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:3000/api/oura/callback
